<odoo>
    <data>
        <!-- Tree View for Records of product sales. -->
        <record id="gym_shop_sale_order_tree_view" model="ir.ui.view">
            <field name="name">gym_shop.sale_order.tree</field>
            <field name="model">gym_shop.sale_order</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="member_id"/>
                    <field name="sale_date"/>
                    <field name="total_amount"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Records of product sales. -->
        <record id="gym_shop_sale_order_form_view" model="ir.ui.view">
            <field name="name">gym_shop.sale_order.form</field>
            <field name="model">gym_shop.sale_order</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="member_id"/>
                            <field name="sale_date"/>
                            <field name="order_line_ids"/>
                            <field name="total_amount"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>