<odoo>
    <data>
        <!-- Tree View for Gym Member -->
        <record id="fitzone.fitzone_member_tree_view" model="ir.ui.view">
            <field name="name">fitzone.member.tree</field>
            <field name="model">fitzone.member</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="phone"/>
                    <field name="plan_id"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Gym Member -->
        <record id="fitzone.fitzone_member_form_view" model="ir.ui.view">
            <field name="name">fitzone.member.form</field>
            <field name="model">fitzone.member</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="plan_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>