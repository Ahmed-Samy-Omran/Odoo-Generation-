<odoo>
    <data noupdate="1">
        <record id="group_warehouse_user" model="res.groups">
            <field name="name">Access/Warehousewarehouse_user</field>
            <field name="comment">Warehouse User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('base.group_user'))]"/>
        </record>

        <record id="access_warehouse_user_product" model="ir.model.access">
            <field name="name">warehouse_user Access to product</field>
            <field name="model_id" ref="product"/>
            <field name="group_id" ref="group_warehouse_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="access_warehouse_user_invoice" model="ir.model.access">
            <field name="name">warehouse_user Access to invoice</field>
            <field name="model_id" ref="invoice"/>
            <field name="group_id" ref="group_warehouse_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="access_warehouse_user_invoice_line" model="ir.model.access">
            <field name="name">warehouse_user Access to invoice.line</field>
            <field name="model_id" ref="invoice_line"/>
            <field name="group_id" ref="group_warehouse_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
        </record>
    </data>
</odoo>