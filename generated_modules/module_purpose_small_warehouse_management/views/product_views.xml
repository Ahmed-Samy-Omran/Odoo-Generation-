<odoo>
    <data>
        <!-- Tree View for Handles product inventory details. -->
        <record id="product_tree_view" model="ir.ui.view">
            <field name="name">product.tree</field>
            <field name="model">product</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="default_code"/>
                    <field name="barcode"/>
                    <field name="list_price"/>
                    <field name="qty_available"/>
                    <field name="storage_location"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Handles product inventory details. -->
        <record id="product_form_view" model="ir.ui.view">
            <field name="name">product.form</field>
            <field name="model">product</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="default_code"/>
                            <field name="barcode"/>
                            <field name="list_price"/>
                            <field name="standard_price"/>
                            <field name="qty_available"/>
                            <field name="min_stock_level"/>
                            <field name="storage_location"/>
                            <field name="expiry_date"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>