<odoo>
    <data>
        <!-- Tree View for Handles individual line items within an invoice. -->
        <record id="invoice_line_tree_view" model="ir.ui.view">
            <field name="name">invoice.line.tree</field>
            <field name="model">invoice.line</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="product_id"/>
                    <field name="quantity"/>
                    <field name="price_unit"/>
                    <field name="price_subtotal"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Handles individual line items within an invoice. -->
        <record id="invoice_line_form_view" model="ir.ui.view">
            <field name="name">invoice.line.form</field>
            <field name="model">invoice.line</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="product_id"/>
                            <field name="quantity"/>
                            <field name="price_unit"/>
                            <field name="price_subtotal"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>