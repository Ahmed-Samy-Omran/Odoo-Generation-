<odoo>
    <data noupdate="1">
        <record id="group_clinic_receptionist" model="res.groups">
            <field name="name">Clinic/Clinic Receptionist</field>
            <field name="comment">Can manage patients and appointments but only read doctors.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="access_clinic_receptionist_patient" model="ir.model.access">
            <field name="name">Clinic Receptionist Access to patient</field>
            <field name="model_id" ref="patient"/>
            <field name="group_id" ref="group_clinic_receptionist"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="access_clinic_receptionist_doctor" model="ir.model.access">
            <field name="name">Clinic Receptionist Access to doctor</field>
            <field name="model_id" ref="doctor"/>
            <field name="group_id" ref="group_clinic_receptionist"/>
            <field name="perm_read">True</field>
            <field name="perm_write">False</field>
            <field name="perm_create">False</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="access_clinic_receptionist_appointment" model="ir.model.access">
            <field name="name">Clinic Receptionist Access to appointment</field>
            <field name="model_id" ref="appointment"/>
            <field name="group_id" ref="group_clinic_receptionist"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="group_clinic_admin" model="res.groups">
            <field name="name">Clinic/Clinic Admin</field>
            <field name="comment">Full access to all clinic management features.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="access_clinic_admin_patient" model="ir.model.access">
            <field name="name">Clinic Admin Access to patient</field>
            <field name="model_id" ref="patient"/>
            <field name="group_id" ref="group_clinic_admin"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
        <record id="access_clinic_admin_doctor" model="ir.model.access">
            <field name="name">Clinic Admin Access to doctor</field>
            <field name="model_id" ref="doctor"/>
            <field name="group_id" ref="group_clinic_admin"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
        <record id="access_clinic_admin_appointment" model="ir.model.access">
            <field name="name">Clinic Admin Access to appointment</field>
            <field name="model_id" ref="appointment"/>
            <field name="group_id" ref="group_clinic_admin"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
    </data>
</odoo>