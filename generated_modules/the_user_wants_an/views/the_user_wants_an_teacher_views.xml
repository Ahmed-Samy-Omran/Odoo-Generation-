<odoo>
    <data>
        <!-- Tree View for Teacher -->
        <record id="the_user_wants_an.the_user_wants_an_teacher_tree_view" model="ir.ui.view">
            <field name="name">the_user_wants_an.teacher.tree</field>
            <field name="model">the_user_wants_an.teacher</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="employee_id"/>
                    <field name="subjects_taught"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Teacher -->
        <record id="the_user_wants_an.the_user_wants_an_teacher_form_view" model="ir.ui.view">
            <field name="name">the_user_wants_an.teacher.form</field>
            <field name="model">the_user_wants_an.teacher</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="employee_id"/>
                            <field name="contact_info"/>
                            <field name="subjects_taught"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>