<odoo>
    <data>
        <!-- Tree View for School Class -->
        <record id="the_user_wants_an.the_user_wants_an_school_class_tree_view" model="ir.ui.view">
            <field name="name">the_user_wants_an.school_class.tree</field>
            <field name="model">the_user_wants_an.school_class</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="capacity"/>
                    <field name="teacher_id"/>
                </tree>
            </field>
        </record>

        <!-- Form View for School Class -->
        <record id="the_user_wants_an.the_user_wants_an_school_class_form_view" model="ir.ui.view">
            <field name="name">the_user_wants_an.school_class.form</field>
            <field name="model">the_user_wants_an.school_class</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="capacity"/>
                            <field name="teacher_id"/>
                            <field name="student_ids"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>