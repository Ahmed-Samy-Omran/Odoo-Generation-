<odoo>
    <data>
        <!-- Tree View for Schedule Entry -->
        <record id="the_user_wants_an.the_user_wants_an_schedule_tree_view" model="ir.ui.view">
            <field name="name">the_user_wants_an.schedule.tree</field>
            <field name="model">the_user_wants_an.schedule</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="class_id"/>
                    <field name="course_id"/>
                    <field name="teacher_id"/>
                    <field name="day_of_week"/>
                    <field name="start_time"/>
                    <field name="end_time"/>
                    <field name="classroom"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Schedule Entry -->
        <record id="the_user_wants_an.the_user_wants_an_schedule_form_view" model="ir.ui.view">
            <field name="name">the_user_wants_an.schedule.form</field>
            <field name="model">the_user_wants_an.schedule</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="class_id"/>
                            <field name="course_id"/>
                            <field name="teacher_id"/>
                            <field name="day_of_week"/>
                            <field name="start_time"/>
                            <field name="end_time"/>
                            <field name="classroom"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>