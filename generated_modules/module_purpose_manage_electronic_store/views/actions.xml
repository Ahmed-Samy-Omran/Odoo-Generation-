<odoo>
    <data>
        <record id="electronic_products_action" model="ir.actions.act_window">
            <field name="name">Electronic Products</field>
            <field name="res_model">product.product</field>
            <field name="view_mode">tree,form,kanban</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage electronic products inventory.</p>
            </field>
        </record>
        <record id="product_categories_action" model="ir.actions.act_window">
            <field name="name">Product Categories</field>
            <field name="res_model">product.category</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage product categories.</p>
            </field>
        </record>
        <record id="sales_orders_action" model="ir.actions.act_window">
            <field name="name">Sales Orders</field>
            <field name="res_model">sale.order</field>
            <field name="view_mode">tree,form,kanban</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage sales orders.</p>
            </field>
        </record>
    </data>
</odoo>