<odoo>
    <data>
        <!-- Tree View for Electronic products inventory management. -->
        <record id="module_purpose_manage_electronic_store.product_product_tree_view" model="ir.ui.view">
            <field name="name">product.product.tree</field>
            <field name="model">product.product</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="internal_reference"/>
                    <field name="category_id"/>
                    <field name="price"/>
                    <field name="quantity"/>
                    <field name="active"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Electronic products inventory management. -->
        <record id="module_purpose_manage_electronic_store.product_product_form_view" model="ir.ui.view">
            <field name="name">product.product.form</field>
            <field name="model">product.product</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="internal_reference"/>
                            <field name="category_id"/>
                            <field name="price"/>
                            <field name="quantity"/>
                            <field name="description"/>
                            <field name="image"/>
                            <field name="barcode"/>
                            <field name="active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>