<odoo>
    <data noupdate="1">
        <record id="group_sales_user" model="res.groups">
            <field name="name">Electronic Store/Sales User</field>
            <field name="comment">Can create and confirm sales orders.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="access_sales_user_sale_order" model="ir.model.access">
            <field name="name">Sales User Access to sale.order</field>
            <field name="model_id" ref="sale_order"/>
            <field name="group_id" ref="group_sales_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="access_sales_user_product_product" model="ir.model.access">
            <field name="name">Sales User Access to product.product</field>
            <field name="model_id" ref="product_product"/>
            <field name="group_id" ref="group_sales_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">False</field>
            <field name="perm_create">False</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="access_sales_user_product_category" model="ir.model.access">
            <field name="name">Sales User Access to product.category</field>
            <field name="model_id" ref="product_category"/>
            <field name="group_id" ref="group_sales_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">False</field>
            <field name="perm_create">False</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="access_sales_user_sale_order_line" model="ir.model.access">
            <field name="name">Sales User Access to sale.order.line</field>
            <field name="model_id" ref="sale_order_line"/>
            <field name="group_id" ref="group_sales_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="group_sales_manager" model="res.groups">
            <field name="name">Electronic Store/Sales Manager</field>
            <field name="comment">Full access to sales and products.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="access_sales_manager_sale_order" model="ir.model.access">
            <field name="name">Sales Manager Access to sale.order</field>
            <field name="model_id" ref="sale_order"/>
            <field name="group_id" ref="group_sales_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
        <record id="access_sales_manager_product_product" model="ir.model.access">
            <field name="name">Sales Manager Access to product.product</field>
            <field name="model_id" ref="product_product"/>
            <field name="group_id" ref="group_sales_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
        <record id="access_sales_manager_product_category" model="ir.model.access">
            <field name="name">Sales Manager Access to product.category</field>
            <field name="model_id" ref="product_category"/>
            <field name="group_id" ref="group_sales_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
        <record id="access_sales_manager_sale_order_line" model="ir.model.access">
            <field name="name">Sales Manager Access to sale.order.line</field>
            <field name="model_id" ref="sale_order_line"/>
            <field name="group_id" ref="group_sales_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
    </data>
</odoo>