<odoo>
    <data noupdate="1">
        <record id="group_gym_manager" model="res.groups">
            <field name="name">GymGym Manager</field>
            <field name="comment">Full access to gym management</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="access_gym_manager_gym_management_trainer" model="ir.model.access">
            <field name="name">Gym Manager Access to gym_management.trainer</field>
            <field name="model_id" ref="gym_management_trainer"/>
            <field name="group_id" ref="group_gym_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
        <record id="access_gym_manager_gym_management_member" model="ir.model.access">
            <field name="name">Gym Manager Access to gym_management.member</field>
            <field name="model_id" ref="gym_management_member"/>
            <field name="group_id" ref="group_gym_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
    </data>
</odoo>