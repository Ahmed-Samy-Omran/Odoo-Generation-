<odoo>
    <data>
        <!-- Tree View for Gym Member -->
        <record id="gym_management.gym_management_member_tree_view" model="ir.ui.view">
            <field name="name">gym_management.member.tree</field>
            <field name="model">gym_management.member</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="join_date"/>
                    <field name="trainer_id"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Gym Member -->
        <record id="gym_management.gym_management_member_form_view" model="ir.ui.view">
            <field name="name">gym_management.member.form</field>
            <field name="model">gym_management.member</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="join_date"/>
                            <field name="trainer_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>