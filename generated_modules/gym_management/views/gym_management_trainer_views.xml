<odoo>
    <data>
        <!-- Tree View for Gym Trainer -->
        <record id="gym_management.gym_management_trainer_tree_view" model="ir.ui.view">
            <field name="name">gym_management.trainer.tree</field>
            <field name="model">gym_management.trainer</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="specialty"/>
                    <field name="salary"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Gym Trainer -->
        <record id="gym_management.gym_management_trainer_form_view" model="ir.ui.view">
            <field name="name">gym_management.trainer.form</field>
            <field name="model">gym_management.trainer</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="specialty"/>
                            <field name="salary"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>