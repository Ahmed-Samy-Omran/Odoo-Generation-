                <p class="o_view_nocontent_smiling_face">Manage all teachers</p>
            </field>
        </record>
        <record id="classes_action" model="ir.actions.act_window">
            <field name="name">Classes</field>
            <field name="res_model">class</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage all classes</p>
            </field>
        </record>
        <record id="courses_action" model="ir.actions.act_window">
            <field name="name">Courses</field>
            <field name="res_model">course</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage all courses</p>
            </field>
