<odoo>
    <data>
        <!-- Tree View for Student -->
        <record id="school_management.student_tree_view" model="ir.ui.view">
            <field name="name">student.tree</field>
            <field name="model">student</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="class_id"/>
                    <field name="enrollment_date"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Student -->
        <record id="school_management.student_form_view" model="ir.ui.view">
            <field name="name">student.form</field>
            <field name="model">student</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="date_of_birth"/>
                            <field name="gender"/>
                            <field name="address"/>
                            <field name="enrollment_date"/>
                            <field name="class_id"/>
                            <field name="guardian_name"/>
                            <field name="guardian_phone"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>