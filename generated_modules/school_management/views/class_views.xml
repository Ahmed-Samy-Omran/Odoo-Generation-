<odoo>
    <data>
        <!-- Tree View for Class -->
        <record id="school_management.class_tree_view" model="ir.ui.view">
            <field name="name">class.tree</field>
            <field name="model">class</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="level"/>
                    <field name="section"/>
                    <field name="capacity"/>
                    <field name="teacher_id"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Class -->
        <record id="school_management.class_form_view" model="ir.ui.view">
            <field name="name">class.form</field>
            <field name="model">class</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="level"/>
                            <field name="section"/>
                            <field name="capacity"/>
                            <field name="teacher_id"/>
                            <field name="room_number"/>
                            <field name="student_ids"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>