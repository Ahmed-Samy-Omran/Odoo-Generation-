<odoo>
    <data>
        <!-- Tree View for Course -->
        <record id="school_management.course_tree_view" model="ir.ui.view">
            <field name="name">course.tree</field>
            <field name="model">course</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="teacher_id"/>
                    <field name="credit_hours"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Course -->
        <record id="school_management.course_form_view" model="ir.ui.view">
            <field name="name">course.form</field>
            <field name="model">course</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="teacher_id"/>
                            <field name="credit_hours"/>
                            <field name="description"/>
                            <field name="grade_ids"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>