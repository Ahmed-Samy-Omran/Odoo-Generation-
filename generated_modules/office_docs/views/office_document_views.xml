<odoo>
    <data>
        <!-- Tree View for Stores document details and attachments with status tracking. -->
        <record id="office_docs.office_document_tree_view" model="ir.ui.view">
            <field name="name">office.document.tree</field>
            <field name="model">office.document</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="doc_type"/>
                    <field name="date"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Stores document details and attachments with status tracking. -->
        <record id="office_docs.office_document_form_view" model="ir.ui.view">
            <field name="name">office.document.form</field>
            <field name="model">office.document</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="doc_type"/>
                            <field name="date"/>
                            <field name="attachment"/>
                            <field name="notes"/>
                            <field name="state"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View for Stores document details and attachments with status tracking. -->
        <record id="office_docs.office_document_search_view" model="ir.ui.view">
            <field name="name">office.document.search</field>
            <field name="model">office.document</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="doc_type"/>
                    <field name="date"/>
                    <field name="state"/>
                    <separator/>
                    <filter name="filter_name" string="Name" domain="[('name', 'ilike', self)]"/>
                    <filter name="filter_doc_type" string="Document Type" domain="[('doc_type', '=', self)]"/>
                    <filter name="filter_date" string="Date" domain="[('date', '=', self)]"/>
                    <filter name="filter_state" string="Status" domain="[('state', '=', self)]"/>
                </search>
            </field>
        </record>

        <!-- Kanban View for Stores document details and attachments with status tracking. -->
        <record id="office_docs.office_document_kanban_view" model="ir.ui.view">
            <field name="name">office.document.kanban</field>
            <field name="model">office.document</field>
            <field name="arch" type="xml">
                <kanban default_group_by="doc_type" default_order="state">
                    <field name="id"/>
<field name="state"/>                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <ul>
                                        <li><strong>Name:</strong> <field name="display_name"/></li>
                                                <li><strong>Document Title:</strong> <field name="name"/></li>
                                                <li><strong>Document Type:</strong> <field name="doc_type"/></li>
                                                <li><strong>Date:</strong> <field name="date"/></li>
                                                <li><strong>File:</strong> <field name="attachment"/></li>
                                                <li><strong>Notes:</strong> <field name="notes"/></li>
                                                <li><strong>Status:</strong> <field name="state"/></li>
                                    </ul>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>



    </data>
</odoo>