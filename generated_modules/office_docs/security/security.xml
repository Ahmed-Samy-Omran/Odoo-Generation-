<odoo>
    <data noupdate="1">
        <record id="group_office_document_user" model="res.groups">
            <field name="name">Office Documents/office_document_user</field>
            <field name="comment">Office Document User</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('base.group_user'))]"/>
        </record>

        <record id="access_office_document_user_office_document" model="ir.model.access">
            <field name="name">office_document_user Access to office.document</field>
            <field name="model_id" ref="office_document"/>
            <field name="group_id" ref="group_office_document_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="group_office_document_manager" model="res.groups">
            <field name="name">Office Documents/office_document_manager</field>
            <field name="comment">Office Document Manager</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('office_docs.group_office_document_user'))]"/>
        </record>

        <record id="access_office_document_manager_office_document" model="ir.model.access">
            <field name="name">office_document_manager Access to office.document</field>
            <field name="model_id" ref="office_document"/>
            <field name="group_id" ref="group_office_document_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
    </data>
</odoo>