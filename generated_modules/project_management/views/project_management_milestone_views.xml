<odoo>
    <data>
        <!-- Tree View for Milestone -->
        <record id="project_management.project_management_milestone_tree_view" model="ir.ui.view">
            <field name="name">project_management.milestone.tree</field>
            <field name="model">project_management.milestone</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="target_date"/>
                    <field name="state"/>
                    <field name="completion_rate"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Milestone -->
        <record id="project_management.project_management_milestone_form_view" model="ir.ui.view">
            <field name="name">project_management.milestone.form</field>
            <field name="model">project_management.milestone</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="project_id"/>
                            <field name="target_date"/>
                            <field name="state"/>
                            <field name="completion_rate"/>
                            <field name="task_ids"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View for Milestone -->
        <record id="project_management.project_management_milestone_search_view" model="ir.ui.view">
            <field name="name">project_management.milestone.search</field>
            <field name="model">project_management.milestone</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="project_id"/>
                    <separator/>
                    <filter name="upcoming" string="Upcoming" domain="[('state', '=', 'pending'), ('target_date', '>=', context_today().strftime('%Y-%m-%d')]"/>
                    <group expand="0" string="Group By">
                        <filter name="project_id" string="Project" context="{'group_by': 'project_id'}"/>
                        <filter name="state" string="Status" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>




    </data>
</odoo>