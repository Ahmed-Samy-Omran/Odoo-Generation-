<odoo>
    <data noupdate="1">
        <record id="group_project_user" model="res.groups">
            <field name="name">Project Management/AccessProject User</field>
            <field name="comment">Basic access to view and create projects and tasks</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="access_project_user_project_management_project" model="ir.model.access">
            <field name="name">Project User Access to project_management.project</field>
            <field name="model_id" ref="project_management_project"/>
            <field name="group_id" ref="group_project_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="access_project_user_project_management_task" model="ir.model.access">
            <field name="name">Project User Access to project_management.task</field>
            <field name="model_id" ref="project_management_task"/>
            <field name="group_id" ref="group_project_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="access_project_user_project_management_milestone" model="ir.model.access">
            <field name="name">Project User Access to project_management.milestone</field>
            <field name="model_id" ref="project_management_milestone"/>
            <field name="group_id" ref="group_project_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">False</field>
            <field name="perm_create">False</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="group_project_manager" model="res.groups">
            <field name="name">Project Management/AccessProject Manager</field>
            <field name="comment">Full access to manage all projects, tasks, and milestones</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('project_management.group_project_user'))]"/>
        </record>

        <record id="access_project_manager_project_management_project" model="ir.model.access">
            <field name="name">Project Manager Access to project_management.project</field>
            <field name="model_id" ref="project_management_project"/>
            <field name="group_id" ref="group_project_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
        <record id="access_project_manager_project_management_task" model="ir.model.access">
            <field name="name">Project Manager Access to project_management.task</field>
            <field name="model_id" ref="project_management_task"/>
            <field name="group_id" ref="group_project_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
        <record id="access_project_manager_project_management_milestone" model="ir.model.access">
            <field name="name">Project Manager Access to project_management.milestone</field>
            <field name="model_id" ref="project_management_milestone"/>
            <field name="group_id" ref="group_project_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
    </data>
</odoo>