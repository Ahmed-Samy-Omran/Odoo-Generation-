<odoo>
    <data>
        <!-- Tree View for Book -->
        <record id="library_management.library_management_book_tree_view" model="ir.ui.view">
            <field name="name">library_management.book.tree</field>
            <field name="model">library_management.book</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="title"/>
                    <field name="author"/>
                    <field name="is_published"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Book -->
        <record id="library_management.library_management_book_form_view" model="ir.ui.view">
            <field name="name">library_management.book.form</field>
            <field name="model">library_management.book</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="title"/>
                            <field name="author"/>
                            <field name="is_published"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View for Book -->
        <record id="library_management.library_management_book_search_view" model="ir.ui.view">
            <field name="name">library_management.book.search</field>
            <field name="model">library_management.book</field>
            <field name="arch" type="xml">
                <search>
                    <field name="title"/>
                    <field name="author"/>
                    <field name="is_published"/>
                    <separator/>
                    <filter name="published_books" string="Published Books" domain="[('is_published', '=', True)]"/>
                    <filter name="unpublished_books" string="Unpublished Books" domain="[('is_published', '=', False)]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_author" string="Author" context="{'group_by': 'group_by_author'}"/>
                        <filter name="group_by_published" string="Published Status" context="{'group_by': 'group_by_published'}"/>
                    </group>
                </search>
            </field>
        </record>




    </data>
</odoo>