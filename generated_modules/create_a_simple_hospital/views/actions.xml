<odoo>
    <data>
        <record id="patients_action" model="ir.actions.act_window">
            <field name="name">Patients</field>
            <field name="res_model">create_a_simple_hospital.patient</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage hospital patients</p>
            </field>
        </record>
        <record id="doctors_action" model="ir.actions.act_window">
            <field name="name">Doctors</field>
            <field name="res_model">create_a_simple_hospital.doctor</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage hospital doctors</p>
            </field>
        </record>
        <record id="appointments_action" model="ir.actions.act_window">
            <field name="name">Appointments</field>
            <field name="res_model">create_a_simple_hospital.appointment</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage hospital appointments</p>
            </field>
        </record>
    </data>
</odoo>