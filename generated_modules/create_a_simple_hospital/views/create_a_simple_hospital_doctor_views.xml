<odoo>
    <data>
        <!-- Tree View for Doctor -->
        <record id="create_a_simple_hospital.create_a_simple_hospital_doctor_tree_view" model="ir.ui.view">
            <field name="name">create_a_simple_hospital.doctor.tree</field>
            <field name="model">create_a_simple_hospital.doctor</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="specialty"/>
                    <field name="phone"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Doctor -->
        <record id="create_a_simple_hospital.create_a_simple_hospital_doctor_form_view" model="ir.ui.view">
            <field name="name">create_a_simple_hospital.doctor.form</field>
            <field name="model">create_a_simple_hospital.doctor</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="specialty"/>
                            <field name="phone"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>