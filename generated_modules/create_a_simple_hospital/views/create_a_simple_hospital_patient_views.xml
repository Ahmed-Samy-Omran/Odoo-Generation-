<odoo>
    <data>
        <!-- Tree View for Patient -->
        <record id="create_a_simple_hospital.create_a_simple_hospital_patient_tree_view" model="ir.ui.view">
            <field name="name">create_a_simple_hospital.patient.tree</field>
            <field name="model">create_a_simple_hospital.patient</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="date_of_birth"/>
                    <field name="gender"/>
                    <field name="phone"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Patient -->
        <record id="create_a_simple_hospital.create_a_simple_hospital_patient_form_view" model="ir.ui.view">
            <field name="name">create_a_simple_hospital.patient.form</field>
            <field name="model">create_a_simple_hospital.patient</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="date_of_birth"/>
                            <field name="gender"/>
                            <field name="phone"/>
                            <field name="address"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>