<odoo>
    <data noupdate="1">
        <record id="group_health_officer" model="res.groups">
            <field name="name">Health Management/AccessHealth Officer</field>
            <field name="comment">Full access to health records</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="access_health_officer_health_management_health_record" model="ir.model.access">
            <field name="name">Health Officer Access to health_management.health_record</field>
            <field name="model_id" ref="health_management_health_record"/>
            <field name="group_id" ref="group_health_officer"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
    </data>
</odoo>