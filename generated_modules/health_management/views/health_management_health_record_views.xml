<odoo>
    <data>
        <!-- Tree View for Health Record -->
        <record id="health_management.health_management_health_record_tree_view" model="ir.ui.view">
            <field name="name">health_management.health_record.tree</field>
            <field name="model">health_management.health_record</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="employee_id"/>
                    <field name="checkup_date"/>
                    <field name="is_urgent"/>
                    <field name="notes"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Health Record -->
        <record id="health_management.health_management_health_record_form_view" model="ir.ui.view">
            <field name="name">health_management.health_record.form</field>
            <field name="model">health_management.health_record</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="employee_id"/>
                            <field name="checkup_date"/>
                            <field name="notes"/>
                            <field name="is_urgent"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>


        <!-- Kanban View for Health Record -->
        <record id="health_management.health_management_health_record_kanban_view" model="ir.ui.view">
            <field name="name">health_management.health_record.kanban</field>
            <field name="model">health_management.health_record</field>
            <field name="arch" type="xml">
                <kanban default_group_by="employee_id" default_order="is_urgent">
                    <field name="id"/>
<field name="is_urgent"/>                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <ul>
                                        <li><strong>Name:</strong> <field name="display_name"/></li>
                                                <li><strong>Employee:</strong> <field name="employee_id"/></li>
                                                <li><strong>Checkup Date:</strong> <field name="checkup_date"/></li>
                                                <li><strong>Notes:</strong> <field name="notes"/></li>
                                                <li><strong>Is Urgent:</strong> <field name="is_urgent"/></li>
                                    </ul>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>



    </data>
</odoo>