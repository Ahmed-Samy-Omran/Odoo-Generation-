<odoo>
    <data>
        <!-- Tree View for Project Task -->
        <record id="project_task_management.project_task_management_task_tree_view" model="ir.ui.view">
            <field name="name">project_task_management.task.tree</field>
            <field name="model">project_task_management.task</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="user_id"/>
                    <field name="priority"/>
                    <field name="state"/>
                    <field name="effective_hours"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Project Task -->
        <record id="project_task_management.project_task_management_task_form_view" model="ir.ui.view">
            <field name="name">project_task_management.task.form</field>
            <field name="model">project_task_management.task</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="project_id"/>
                            <field name="user_id"/>
                            <field name="priority"/>
                            <field name="state"/>
                            <field name="description"/>
                            <field name="tag_ids"/>
                            <field name="planned_hours"/>
                            <field name="effective_hours"/>
                            <field name="remaining_hours"/>
                            <field name="timesheet_ids"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View for Project Task -->
        <record id="project_task_management.project_task_management_task_search_view" model="ir.ui.view">
            <field name="name">project_task_management.task.search</field>
            <field name="model">project_task_management.task</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="user_id"/>
                    <field name="priority"/>
                    <field name="state"/>
                    <separator/>
                    <filter name="filter_high_priority" string="High Priority" domain="[('priority', '=', 'high')]"/>
                    <filter name="filter_in_progress" string="In Progress" domain="[('state', '=', 'in_progress')]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_project" string="Project" context="{'group_by': 'group_by_project'}"/>
                        <filter name="group_by_user" string="Assigned To" context="{'group_by': 'group_by_user'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Kanban View for Project Task -->
        <record id="project_task_management.project_task_management_task_kanban_view" model="ir.ui.view">
            <field name="name">project_task_management.task.kanban</field>
            <field name="model">project_task_management.task</field>
            <field name="arch" type="xml">
                <kanban  default_order="color">
                    <field name="id"/>
<field name="color"/>                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <ul>
                                        <li><strong>Name:</strong> <field name="display_name"/></li>
                                                <li><strong>Task Title:</strong> <field name="name"/></li>
                                                <li><strong>Project:</strong> <field name="project_id"/></li>
                                                <li><strong>Assigned To:</strong> <field name="user_id"/></li>
                                                <li><strong>Priority:</strong> <field name="priority"/></li>
                                                <li><strong>Status:</strong> <field name="state"/></li>
                                                <li><strong>Description:</strong> <field name="description"/></li>
                                                <li><strong>Tags:</strong> <field name="tag_ids"/></li>
                                                <li><strong>Planned Hours:</strong> <field name="planned_hours"/></li>
                                                <li><strong>Effective Hours:</strong> <field name="effective_hours"/></li>
                                                <li><strong>Remaining Hours:</strong> <field name="remaining_hours"/></li>
                                                <li><strong>Timesheets:</strong> <field name="timesheet_ids"/></li>
                                                <li><strong>Start Date:</strong> <field name="start_date"/></li>
                                                <li><strong>End Date:</strong> <field name="end_date"/></li>
                                                <li><strong>Color Index:</strong> <field name="color"/></li>
                                    </ul>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Calendar View for Project Task -->
        <record id="project_task_management.project_task_management_task_calendar_view" model="ir.ui.view">
            <field name="name">project_task_management.task.calendar</field>
            <field name="model">project_task_management.task</field>
            <field name="arch" type="xml">
                <calendar date_start="start_date" date_stop="end_date"  color="user_id">
                    <field name="display_name"/>
                </calendar>
            </field>
        </record>


    </data>
</odoo>