<odoo>
    <data>
        <!-- Tree View for Property -->
        <record id="test_7.test_7_property_tree_view" model="ir.ui.view">
            <field name="name">test_7.property.tree</field>
            <field name="model">test_7.property</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="price"/>
                    <field name="status"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Property -->
        <record id="test_7.test_7_property_form_view" model="ir.ui.view">
            <field name="name">test_7.property.form</field>
            <field name="model">test_7.property</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="price"/>
                            <field name="status"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View for Property -->
        <record id="test_7.test_7_property_search_view" model="ir.ui.view">
            <field name="name">test_7.property.search</field>
            <field name="model">test_7.property</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="price"/>
                    <field name="status"/>
                    <separator/>
                    <filter name="available_properties" string="Available" domain="[('status', '=', 'available')]"/>
                    <filter name="sold_properties" string="Sold" domain="[('status', '=', 'sold')]"/>
                    <filter name="reserved_properties" string="Reserved" domain="[('status', '=', 'reserved')]"/>
                    <group expand="0" string="Group By">
                        <filter name="status_group" string="Status" context="{'group_by': 'status_group'}"/>
                    </group>
                </search>
            </field>
        </record>




    </data>
</odoo>