<odoo>
    <data>
        <!-- Tree View for  -->
        <record id="string_tree_view" model="ir.ui.view">
            <field name="name">string.tree</field>
            <field name="model">string</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="string"/>
                </tree>
            </field>
        </record>

        <!-- Form View for  -->
        <record id="string_form_view" model="ir.ui.view">
            <field name="name">string.form</field>
            <field name="model">string</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="string"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View for  -->
        <record id="string_search_view" model="ir.ui.view">
            <field name="name">string.search</field>
            <field name="model">string</field>
            <field name="arch" type="xml">
                <search>
                    <field name="string"/>
                    <separator/>
                    <filter name="string" string="string" domain="string"/>
                    <group expand="0" string="Group By">
                        <filter name="string" string="string" context="{\'group_by\': \'string\'}"/>
                    </group>
                </search>
            </field>
        </record>
    </data>
</odoo>