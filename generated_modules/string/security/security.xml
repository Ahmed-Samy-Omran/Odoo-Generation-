<odoo>
    <data noupdate="1">
        <record id="group_string" model="res.groups">
            <field name="name">Access/string</field>
            <field name="comment">string</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('string'))]"/>
        </record>

        <record id="access_string_string" model="ir.model.access">
            <field name="name">string Access to string</field>
            <field name="model_id" ref="string"/>
            <field name="group_id" ref="group_string"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
    </data>
</odoo>