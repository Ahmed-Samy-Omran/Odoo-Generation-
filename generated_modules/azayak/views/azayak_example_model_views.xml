<odoo>
    <data>
        <!-- Tree View for Example Model for Azayak -->
        <record id="azayak.azayak_example_model_tree_view" model="ir.ui.view">
            <field name="name">azayak.example_model.tree</field>
            <field name="model">azayak.example_model</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Example Model for Azayak -->
        <record id="azayak.azayak_example_model_form_view" model="ir.ui.view">
            <field name="name">azayak.example_model.form</field>
            <field name="model">azayak.example_model</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>