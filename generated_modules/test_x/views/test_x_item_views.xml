<odoo>
    <data>
        <!-- Tree View for  -->
        <record id="test_x.test_x_item_tree_view" model="ir.ui.view">
            <field name="name">test_x.item.tree</field>
            <field name="model">test_x.item</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="title"/>
                </tree>
            </field>
        </record>

        <!-- Form View for  -->
        <record id="test_x.test_x_item_form_view" model="ir.ui.view">
            <field name="name">test_x.item.form</field>
            <field name="model">test_x.item</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="title"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>