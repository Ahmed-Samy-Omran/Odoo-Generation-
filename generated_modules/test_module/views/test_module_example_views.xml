<odoo>
    <data>
        <!-- Tree View for Example Model -->
        <record id="test_module.test_module_example_tree_view" model="ir.ui.view">
            <field name="name">test_module.example.tree</field>
            <field name="model">test_module.example</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="active"/>
                    <field name="date_field"/>
                    <field name="integer_field"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Example Model -->
        <record id="test_module.test_module_example_form_view" model="ir.ui.view">
            <field name="name">test_module.example.form</field>
            <field name="model">test_module.example</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="active"/>
                            <field name="date_field"/>
                            <field name="datetime_field"/>
                            <field name="integer_field"/>
                            <field name="float_field"/>
                            <field name="selection_field"/>
                            <field name="many2one_field"/>
                            <field name="one2many_field"/>
                            <field name="many2many_field"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View for Example Model -->
        <record id="test_module.test_module_example_search_view" model="ir.ui.view">
            <field name="name">test_module.example.search</field>
            <field name="model">test_module.example</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="active"/>
                    <field name="date_field"/>
                    <separator/>
                    <filter name="active_filter" string="Active" domain="[('active', '=', True)]"/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_active" string="Active" context="{'group_by': 'group_by_active'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Kanban View for Example Model -->
        <record id="test_module.test_module_example_kanban_view" model="ir.ui.view">
            <field name="name">test_module.example.kanban</field>
            <field name="model">test_module.example</field>
            <field name="arch" type="xml">
                <kanban default_group_by="active" default_order="selection_field">
                    <field name="id"/>
<field name="selection_field"/>                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <ul>
                                        <li><strong>Name:</strong> <field name="display_name"/></li>
                                                <li><strong>Name:</strong> <field name="name"/></li>
                                                <li><strong>Description:</strong> <field name="description"/></li>
                                                <li><strong>Active:</strong> <field name="active"/></li>
                                                <li><strong>Date:</strong> <field name="date_field"/></li>
                                                <li><strong>Date and Time:</strong> <field name="datetime_field"/></li>
                                                <li><strong>Integer Value:</strong> <field name="integer_field"/></li>
                                                <li><strong>Float Value:</strong> <field name="float_field"/></li>
                                                <li><strong>Selection:</strong> <field name="selection_field"/></li>
                                                <li><strong>Many2One Relation:</strong> <field name="many2one_field"/></li>
                                                <li><strong>One2Many Relation:</strong> <field name="one2many_field"/></li>
                                                <li><strong>Many2Many Relation:</strong> <field name="many2many_field"/></li>
                                    </ul>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Calendar View for Example Model -->
        <record id="test_module.test_module_example_calendar_view" model="ir.ui.view">
            <field name="name">test_module.example.calendar</field>
            <field name="model">test_module.example</field>
            <field name="arch" type="xml">
                <calendar date_start="date_field"   >
                    <field name="display_name"/>
                </calendar>
            </field>
        </record>


    </data>
</odoo>