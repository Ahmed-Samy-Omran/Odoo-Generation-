<odoo>
    <data>
        <!-- Tree View for Member -->
        <record id="test_gym.test_gym_member_tree_view" model="ir.ui.view">
            <field name="name">test_gym.member.tree</field>
            <field name="model">test_gym.member</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="phone"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Member -->
        <record id="test_gym.test_gym_member_form_view" model="ir.ui.view">
            <field name="name">test_gym.member.form</field>
            <field name="model">test_gym.member</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="phone"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>