<odoo>
    <data>
        <!-- Tree View for Manages gym trainers. -->
        <record id="gym_core_trainer_tree_view" model="ir.ui.view">
            <field name="name">gym_core.trainer.tree</field>
            <field name="model">gym_core.trainer</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="specialty"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Manages gym trainers. -->
        <record id="gym_core_trainer_form_view" model="ir.ui.view">
            <field name="name">gym_core.trainer.form</field>
            <field name="model">gym_core.trainer</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="specialty"/>
                            <field name="member_ids"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>