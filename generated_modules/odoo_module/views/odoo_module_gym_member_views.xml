<odoo>
    <data>
        <!-- Tree View for Gym Member -->
        <record id="odoo_module.odoo_module_gym_member_tree_view" model="ir.ui.view">
            <field name="name">odoo_module.gym_member.tree</field>
            <field name="model">odoo_module.gym_member</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="membership_plan_id"/>
                    <field name="is_active"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Gym Member -->
        <record id="odoo_module.odoo_module_gym_member_form_view" model="ir.ui.view">
            <field name="name">odoo_module.gym_member.form</field>
            <field name="model">odoo_module.gym_member</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="membership_plan_id"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="is_active"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>