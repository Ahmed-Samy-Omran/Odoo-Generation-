<odoo>
    <data>
        <!-- Tree View for Gym Trainer -->
        <record id="odoo_module.odoo_module_gym_trainer_tree_view" model="ir.ui.view">
            <field name="name">odoo_module.gym_trainer.tree</field>
            <field name="model">odoo_module.gym_trainer</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="specialization"/>
                    <field name="phone"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Gym Trainer -->
        <record id="odoo_module.odoo_module_gym_trainer_form_view" model="ir.ui.view">
            <field name="name">odoo_module.gym_trainer.form</field>
            <field name="model">odoo_module.gym_trainer</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="specialization"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>