<odoo>
    <data>
        <!-- Tree View for My Custom Model -->
        <record id="my_custom_module.my_custom_module_my_model_tree_view" model="ir.ui.view">
            <field name="name">my_custom_module.my_model.tree</field>
            <field name="model">my_custom_module.my_model</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="description"/>
                </tree>
            </field>
        </record>

        <!-- Form View for My Custom Model -->
        <record id="my_custom_module.my_custom_module_my_model_form_view" model="ir.ui.view">
            <field name="name">my_custom_module.my_model.form</field>
            <field name="model">my_custom_module.my_model</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>