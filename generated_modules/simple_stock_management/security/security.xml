<odoo>
    <data noupdate="1">
        <record id="group_stock_manager" model="res.groups">
            <field name="name">Stock/Stock Manager</field>
            <field name="comment">Manage stock products and movements.</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="access_stock_manager_product_product" model="ir.model.access">
            <field name="name">Stock Manager Access to product.product</field>
            <field name="model_id" ref="product_product"/>
            <field name="group_id" ref="group_stock_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
        <record id="access_stock_manager_stock_move" model="ir.model.access">
            <field name="name">Stock Manager Access to stock.move</field>
            <field name="model_id" ref="stock_move"/>
            <field name="group_id" ref="group_stock_manager"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
    </data>
</odoo>