<odoo>
    <data>
        <!-- Tree View for Manage products in stock. -->
        <record id="simple_stock_management.product_product_tree_view" model="ir.ui.view">
            <field name="name">product.product.tree</field>
            <field name="model">product.product</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="quantity"/>
                    <field name="price"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Manage products in stock. -->
        <record id="simple_stock_management.product_product_form_view" model="ir.ui.view">
            <field name="name">product.product.form</field>
            <field name="model">product.product</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="quantity"/>
                            <field name="price"/>
                            <field name="stock_move_ids"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>