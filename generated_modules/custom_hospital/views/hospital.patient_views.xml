<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_custom_hospital_hospital_patient_form" model="ir.ui.view">
            <field name="name">Hospital.Patient Form</field>
            <field name="model">custom_hospital.hospital.patient</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>                                <field name="name" />                                <field name="gender" />                            </group>
                            <group>                                <field name="age" />                                <field name="doctor_id" />                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_custom_hospital_hospital_patient_tree" model="ir.ui.view">
            <field name="name">Hospital.Patient Tree</field>
            <field name="model">custom_hospital.hospital.patient</field>
            <field name="arch" type="xml">
                <tree>                    <field name="name" />                    <field name="age" />                    <field name="gender" />                    <field name="doctor_id" />                </tree>
            </field>
        </record>

        <record id="view_custom_hospital_hospital_patient_search" model="ir.ui.view">
            <field name="name">Hospital.Patient Search</field>
            <field name="model">custom_hospital.hospital.patient</field>
            <field name="arch" type="xml">
                <search>                    <field name="name" />                    <field name="age" />                    <field name="gender" />                    <field name="doctor_id" />                </search>
            </field>
        </record>

        <record id="action_custom_hospital_hospital_patient" model="ir.actions.act_window">
            <field name="name">Hospital.Patient</field>
            <field name="res_model">custom_hospital.hospital.patient</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new hospital.patient
                </p>
            </field>
        </record>

        <menuitem
            id="menu_custom_hospital_hospital_patient_root"
            name="Hospital.Patient Management"
            web_icon="base,static/description/icon.png"
            sequence="10" />

        <menuitem
            id="menu_custom_hospital_hospital_patient_child"
            name="Hospital.Patient"
            parent="menu_custom_hospital_hospital_patient_root"
            action="action_custom_hospital_hospital_patient"
            sequence="10" />
    </data>
</odoo>