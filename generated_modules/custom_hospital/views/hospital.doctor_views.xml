<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_custom_hospital_hospital_doctor_form" model="ir.ui.view">
            <field name="name">Hospital.Doctor Form</field>
            <field name="model">custom_hospital.hospital.doctor</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>                                <field name="name" />                            </group>
                            <group>                                <field name="specialty" />                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_custom_hospital_hospital_doctor_tree" model="ir.ui.view">
            <field name="name">Hospital.Doctor Tree</field>
            <field name="model">custom_hospital.hospital.doctor</field>
            <field name="arch" type="xml">
                <tree>                    <field name="name" />                    <field name="specialty" />                </tree>
            </field>
        </record>

        <record id="view_custom_hospital_hospital_doctor_search" model="ir.ui.view">
            <field name="name">Hospital.Doctor Search</field>
            <field name="model">custom_hospital.hospital.doctor</field>
            <field name="arch" type="xml">
                <search>                    <field name="name" />                    <field name="specialty" />                </search>
            </field>
        </record>

        <record id="action_custom_hospital_hospital_doctor" model="ir.actions.act_window">
            <field name="name">Hospital.Doctor</field>
            <field name="res_model">custom_hospital.hospital.doctor</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new hospital.doctor
                </p>
            </field>
        </record>

        <menuitem
            id="menu_custom_hospital_hospital_doctor_root"
            name="Hospital.Doctor Management"
            web_icon="base,static/description/icon.png"
            sequence="10" />

        <menuitem
            id="menu_custom_hospital_hospital_doctor_child"
            name="Hospital.Doctor"
            parent="menu_custom_hospital_hospital_doctor_root"
            action="action_custom_hospital_hospital_doctor"
            sequence="10" />
    </data>
</odoo>