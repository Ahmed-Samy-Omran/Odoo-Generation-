<odoo>
    <data>
        <!-- Tree View for Todo Task -->
        <record id="todo_task_management_todo_task_tree_view" model="ir.ui.view">
            <field name="name">todo_task_management.todo_task.tree</field>
            <field name="model">todo_task_management.todo_task</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="dead_line"/>
                    <field name="status"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Todo Task -->
        <record id="todo_task_management_todo_task_form_view" model="ir.ui.view">
            <field name="name">todo_task_management.todo_task.form</field>
            <field name="model">todo_task_management.todo_task</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="dead_line"/>
                            <field name="status"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>