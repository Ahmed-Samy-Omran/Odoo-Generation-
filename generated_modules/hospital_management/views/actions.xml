<odoo>
    <data>
        <record id="patients_action" model="ir.actions.act_window">
            <field name="name">Patients</field>
            <field name="res_model">hospital.patient</field>
            <field name="view_mode">tree,form</field>
<field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage your hospital patients</p>
            </field>        </record>
        <record id="doctors_action" model="ir.actions.act_window">
            <field name="name">Doctors</field>
            <field name="res_model">hospital.doctor</field>
            <field name="view_mode">tree,form</field>
<field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage your hospital doctors</p>
            </field>        </record>
        <record id="appointments_action" model="ir.actions.act_window">
            <field name="name">Appointments</field>
            <field name="res_model">hospital.appointment</field>
            <field name="view_mode">tree,form</field>
<field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage patient appointments</p>
            </field>        </record>
    </data>
</odoo>