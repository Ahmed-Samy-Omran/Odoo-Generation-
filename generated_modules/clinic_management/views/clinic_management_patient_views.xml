<odoo>
    <data>
        <!-- Tree View for Patient -->
        <record id="clinic_management.clinic_management_patient_tree_view" model="ir.ui.view">
            <field name="name">clinic_management.patient.tree</field>
            <field name="model">clinic_management.patient</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="phone"/>
                    <field name="email"/>
                    <field name="date_of_birth"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Patient -->
        <record id="clinic_management.clinic_management_patient_form_view" model="ir.ui.view">
            <field name="name">clinic_management.patient.form</field>
            <field name="model">clinic_management.patient</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="phone"/>
                            <field name="email"/>
                            <field name="date_of_birth"/>
                            <field name="gender"/>
                            <field name="address"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View for Patient -->
        <record id="clinic_management.clinic_management_patient_search_view" model="ir.ui.view">
            <field name="name">clinic_management.patient.search</field>
            <field name="model">clinic_management.patient</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="phone"/>
                </search>
            </field>
        </record>




    </data>
</odoo>