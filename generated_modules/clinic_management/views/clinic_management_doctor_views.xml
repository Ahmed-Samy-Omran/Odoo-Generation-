<odoo>
    <data>
        <!-- Tree View for Doctor -->
        <record id="clinic_management.clinic_management_doctor_tree_view" model="ir.ui.view">
            <field name="name">clinic_management.doctor.tree</field>
            <field name="model">clinic_management.doctor</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="specialization"/>
                    <field name="consultation_price"/>
                    <field name="total_consultation_earnings"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Doctor -->
        <record id="clinic_management.clinic_management_doctor_form_view" model="ir.ui.view">
            <field name="name">clinic_management.doctor.form</field>
            <field name="model">clinic_management.doctor</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="specialization"/>
                            <field name="consultation_price"/>
                            <field name="total_consultation_earnings"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>