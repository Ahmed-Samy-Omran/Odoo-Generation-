<odoo>
    <data noupdate="1">
        <record id="group_receptionist" model="res.groups">
            <field name="name">Clinic ManagementReceptionist</field>
            <field name="comment">Access rights for receptionists</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user')), (4, ref('base.group_user'))]"/>
        </record>

        <record id="access_receptionist_clinic_management_patient" model="ir.model.access">
            <field name="name">Receptionist Access to clinic_management.patient</field>
            <field name="model_id" ref="clinic_management_patient"/>
            <field name="group_id" ref="group_receptionist"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="access_receptionist_clinic_management_doctor" model="ir.model.access">
            <field name="name">Receptionist Access to clinic_management.doctor</field>
            <field name="model_id" ref="clinic_management_doctor"/>
            <field name="group_id" ref="group_receptionist"/>
            <field name="perm_read">True</field>
            <field name="perm_write">False</field>
            <field name="perm_create">False</field>
            <field name="perm_unlink">False</field>
        </record>
        <record id="access_receptionist_clinic_management_appointment" model="ir.model.access">
            <field name="name">Receptionist Access to clinic_management.appointment</field>
            <field name="model_id" ref="clinic_management_appointment"/>
            <field name="group_id" ref="group_receptionist"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
    </data>
</odoo>