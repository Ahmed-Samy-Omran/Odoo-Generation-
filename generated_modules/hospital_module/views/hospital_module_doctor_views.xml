<odoo>
    <data>
        <!-- Tree View for Doctor Records -->
        <record id="hospital_module_doctor_tree_view" model="ir.ui.view">
            <field name="name">hospital_module.doctor.tree</field>
            <field name="model">hospital_module.doctor</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="specialty"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Doctor Records -->
        <record id="hospital_module_doctor_form_view" model="ir.ui.view">
            <field name="name">hospital_module.doctor.form</field>
            <field name="model">hospital_module.doctor</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="specialty"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View for Doctor Records -->
    </data>
</odoo>