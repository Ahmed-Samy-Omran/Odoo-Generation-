<odoo>
    <data noupdate="1">
        <record id="group_demo_user" model="res.groups">
            <field name="name">Access/Demo User</field>
            <field name="comment">User access for demo deploy</field>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="access_demo_user_demo_deploy_demo_model" model="ir.model.access">
            <field name="name">Demo User Access to demo_deploy.demo_model</field>
            <field name="model_id" ref="demo_deploy_demo_model"/>
            <field name="group_id" ref="group_demo_user"/>
            <field name="perm_read">True</field>
            <field name="perm_write">True</field>
            <field name="perm_create">True</field>
            <field name="perm_unlink">True</field>
        </record>
    </data>
</odoo>