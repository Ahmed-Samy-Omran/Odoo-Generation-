<odoo>
    <data>
        <!-- Tree View for Membership Plan -->
        <record id="odoo_module.odoo_module_membership_plan_tree_view" model="ir.ui.view">
            <field name="name">odoo_module.membership_plan.tree</field>
            <field name="model">odoo_module.membership_plan</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="price"/>
                    <field name="duration_days"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Membership Plan -->
        <record id="odoo_module.odoo_module_membership_plan_form_view" model="ir.ui.view">
            <field name="name">odoo_module.membership_plan.form</field>
            <field name="model">odoo_module.membership_plan</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="price"/>
                            <field name="duration_days"/>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>