<odoo>
    <data>
        <!-- Tree View for Gym Class -->
        <record id="odoo_module.odoo_module_gym_class_tree_view" model="ir.ui.view">
            <field name="name">odoo_module.gym_class.tree</field>
            <field name="model">odoo_module.gym_class</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="trainer_id"/>
                    <field name="schedule_datetime"/>
                    <field name="capacity"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Gym Class -->
        <record id="odoo_module.odoo_module_gym_class_form_view" model="ir.ui.view">
            <field name="name">odoo_module.gym_class.form</field>
            <field name="model">odoo_module.gym_class</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="trainer_id"/>
                            <field name="schedule_datetime"/>
                            <field name="capacity"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>



        <!-- Calendar View for Gym Class -->
        <record id="odoo_module.odoo_module_gym_class_calendar_view" model="ir.ui.view">
            <field name="name">odoo_module.gym_class.calendar</field>
            <field name="model">odoo_module.gym_class</field>
            <field name="arch" type="xml">
                <calendar date_start="schedule_datetime"   >
                    <field name="display_name"/>
                </calendar>
            </field>
        </record>


    </data>
</odoo>