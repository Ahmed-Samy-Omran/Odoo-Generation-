<odoo>
    <data>
        <!-- Tree View for Patient Records -->
        <record id="hospital_module_patient_tree_view" model="ir.ui.view">
            <field name="name">hospital_module.patient.tree</field>
            <field name="model">hospital_module.patient</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="age"/>
                    <field name="doctor_id"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Patient Records -->
        <record id="hospital_module_patient_form_view" model="ir.ui.view">
            <field name="name">hospital_module.patient.form</field>
            <field name="model">hospital_module.patient</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="age"/>
                            <field name="doctor_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View for Patient Records -->
    </data>
</odoo>