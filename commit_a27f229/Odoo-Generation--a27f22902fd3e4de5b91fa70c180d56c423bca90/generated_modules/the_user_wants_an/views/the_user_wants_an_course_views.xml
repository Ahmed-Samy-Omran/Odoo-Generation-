<odoo>
    <data>
        <!-- Tree View for Course -->
        <record id="the_user_wants_an.the_user_wants_an_course_tree_view" model="ir.ui.view">
            <field name="name">the_user_wants_an.course.tree</field>
            <field name="model">the_user_wants_an.course</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="course_code"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Course -->
        <record id="the_user_wants_an.the_user_wants_an_course_form_view" model="ir.ui.view">
            <field name="name">the_user_wants_an.course.form</field>
            <field name="model">the_user_wants_an.course</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="course_code"/>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>