<odoo>
    <data>
        <!-- Tree View for Task -->
        <record id="project_management.project_management_task_tree_view" model="ir.ui.view">
            <field name="name">project_management.task.tree</field>
            <field name="model">project_management.task</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="assigned_to_id"/>
                    <field name="priority"/>
                    <field name="state"/>
                    <field name="due_date"/>
                    <field name="estimated_hours"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Task -->
        <record id="project_management.project_management_task_form_view" model="ir.ui.view">
            <field name="name">project_management.task.form</field>
            <field name="model">project_management.task</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="project_id"/>
                            <field name="milestone_id"/>
                            <field name="assigned_to_id"/>
                            <field name="priority"/>
                            <field name="state"/>
                            <field name="start_date"/>
                            <field name="due_date"/>
                            <field name="estimated_hours"/>
                            <field name="actual_hours"/>
                            <field name="completion_percentage"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View for Task -->
        <record id="project_management.project_management_task_search_view" model="ir.ui.view">
            <field name="name">project_management.task.search</field>
            <field name="model">project_management.task</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="project_id"/>
                    <field name="assigned_to_id"/>
                    <separator/>
                    <filter name="my_tasks" string="My Tasks" domain="[('assigned_to_id.user_id', '=', uid)]"/>
                    <filter name="overdue" string="Overdue" domain="[('is_overdue', '=', True)]"/>
                    <filter name="high_priority" string="High Priority" domain="[('priority', 'in', ['high', 'urgent'])]"/>
                    <group expand="0" string="Group By">
                        <filter name="project_id" string="Project" context="{'group_by': 'project_id'}"/>
                        <filter name="assigned_to_id" string="Assigned To" context="{'group_by': 'assigned_to_id'}"/>
                        <filter name="state" string="Status" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Kanban View for Task -->
        <record id="project_management.project_management_task_kanban_view" model="ir.ui.view">
            <field name="name">project_management.task.kanban</field>
            <field name="model">project_management.task</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" default_order="priority">
                    <field name="id"/>
<field name="priority"/>                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <ul>
                                        <li><strong>Name:</strong> <field name="display_name"/></li>
                                                <li><strong>Task Name:</strong> <field name="name"/></li>
                                                <li><strong>Description:</strong> <field name="description"/></li>
                                                <li><strong>Project:</strong> <field name="project_id"/></li>
                                                <li><strong>Milestone:</strong> <field name="milestone_id"/></li>
                                                <li><strong>Assigned To:</strong> <field name="assigned_to_id"/></li>
                                                <li><strong>Priority:</strong> <field name="priority"/></li>
                                                <li><strong>Status:</strong> <field name="state"/></li>
                                                <li><strong>Start Date:</strong> <field name="start_date"/></li>
                                                <li><strong>Due Date:</strong> <field name="due_date"/></li>
                                                <li><strong>Estimated Hours:</strong> <field name="estimated_hours"/></li>
                                                <li><strong>Actual Hours:</strong> <field name="actual_hours"/></li>
                                                <li><strong>Completion %:</strong> <field name="completion_percentage"/></li>
                                                <li><strong>Is Overdue:</strong> <field name="is_overdue"/></li>
                                                <li><strong>Color Index:</strong> <field name="color"/></li>
                                                <li><strong>Active:</strong> <field name="active"/></li>
                                    </ul>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <!-- Calendar View for Task -->
        <record id="project_management.project_management_task_calendar_view" model="ir.ui.view">
            <field name="name">project_management.task.calendar</field>
            <field name="model">project_management.task</field>
            <field name="arch" type="xml">
                <calendar date_start="start_date" date_stop="due_date"  color="assigned_to_id">
                    <field name="display_name"/>
                </calendar>
            </field>
        </record>


    </data>
</odoo>