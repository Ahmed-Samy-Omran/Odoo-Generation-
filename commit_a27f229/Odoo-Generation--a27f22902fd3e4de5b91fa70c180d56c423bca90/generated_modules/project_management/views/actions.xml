<odoo>
    <data>
        <record id="projects_action" model="ir.actions.act_window">
            <field name="name">Projects</field>
            <field name="res_model">project_management.project</field>
            <field name="view_mode">kanban,tree,form,calendar</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Create and manage projects with comprehensive tracking and collaboration features</p>
            </field>
        </record>
        <record id="tasks_action" model="ir.actions.act_window">
            <field name="name">Tasks</field>
            <field name="res_model">project_management.task</field>
            <field name="view_mode">kanban,tree,form,calendar</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Manage project tasks with priority tracking and assignment capabilities</p>
            </field>
        </record>
        <record id="milestones_action" model="ir.actions.act_window">
            <field name="name">Milestones</field>
            <field name="res_model">project_management.milestone</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Define and track project milestones and key deliverables</p>
            </field>
        </record>
    </data>
</odoo>