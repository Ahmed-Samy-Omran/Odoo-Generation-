<odoo>
    <data>
        <!-- Tree View for Project -->
        <record id="project_management.project_management_project_tree_view" model="ir.ui.view">
            <field name="name">project_management.project.tree</field>
            <field name="model">project_management.project</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="manager_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="state"/>
                    <field name="progress"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Project -->
        <record id="project_management.project_management_project_form_view" model="ir.ui.view">
            <field name="name">project_management.project.form</field>
            <field name="model">project_management.project</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="description"/>
                            <field name="manager_id"/>
                            <field name="team_ids"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="budget"/>
                            <field name="state"/>
                            <field name="progress"/>
                            <field name="total_hours"/>
                            <field name="task_ids"/>
                            <field name="milestone_ids"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Search View for Project -->
        <record id="project_management.project_management_project_search_view" model="ir.ui.view">
            <field name="name">project_management.project.search</field>
            <field name="model">project_management.project</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="manager_id"/>
                    <separator/>
                    <filter name="active_projects" string="Active Projects" domain="[('state', '=', 'active')]"/>
                    <filter name="my_projects" string="My Projects" domain="[('manager_id.user_id', '=', uid)]"/>
                    <group expand="0" string="Group By">
                        <filter name="manager_id" string="Project Manager" context="{'group_by': 'manager_id'}"/>
                        <filter name="state" string="Status" context="{'group_by': 'state'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Kanban View for Project -->
        <record id="project_management.project_management_project_kanban_view" model="ir.ui.view">
            <field name="name">project_management.project.kanban</field>
            <field name="model">project_management.project</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" default_order="color">
                    <field name="id"/>
<field name="color"/>                    <templates>
                        <t t-name="kanban-box">
                            <div t-attf-class="oe_kanban_global_click">
                                <div class="oe_kanban_details">
                                    <ul>
                                        <li><strong>Name:</strong> <field name="display_name"/></li>
                                                <li><strong>Project Name:</strong> <field name="name"/></li>
                                                <li><strong>Project Code:</strong> <field name="code"/></li>
                                                <li><strong>Description:</strong> <field name="description"/></li>
                                                <li><strong>Start Date:</strong> <field name="start_date"/></li>
                                                <li><strong>End Date:</strong> <field name="end_date"/></li>
                                                <li><strong>Status:</strong> <field name="state"/></li>
                                                <li><strong>Project Manager:</strong> <field name="manager_id"/></li>
                                                <li><strong>Team Members:</strong> <field name="team_ids"/></li>
                                                <li><strong>Tasks:</strong> <field name="task_ids"/></li>
                                                <li><strong>Milestones:</strong> <field name="milestone_ids"/></li>
                                                <li><strong>Budget:</strong> <field name="budget"/></li>
                                                <li><strong>Total Hours:</strong> <field name="total_hours"/></li>
                                                <li><strong>Progress (%):</strong> <field name="progress"/></li>
                                                <li><strong>Color Index:</strong> <field name="color"/></li>
                                                <li><strong>Active:</strong> <field name="active"/></li>
                                    </ul>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>



    </data>
</odoo>