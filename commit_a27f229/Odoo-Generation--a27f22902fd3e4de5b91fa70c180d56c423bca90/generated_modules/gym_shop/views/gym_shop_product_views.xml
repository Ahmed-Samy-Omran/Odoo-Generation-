<odoo>
    <data>
        <!-- Tree View for Products sold in the gym shop. -->
        <record id="gym_shop_product_tree_view" model="ir.ui.view">
            <field name="name">gym_shop.product.tree</field>
            <field name="model">gym_shop.product</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="product_type"/>
                    <field name="price"/>
                    <field name="quantity_on_hand"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Products sold in the gym shop. -->
        <record id="gym_shop_product_form_view" model="ir.ui.view">
            <field name="name">gym_shop.product.form</field>
            <field name="model">gym_shop.product</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="description"/>
                            <field name="product_type"/>
                            <field name="price"/>
                            <field name="quantity_on_hand"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>