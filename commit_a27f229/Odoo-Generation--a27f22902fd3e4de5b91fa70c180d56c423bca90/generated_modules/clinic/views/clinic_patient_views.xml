<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_clinic_patient_tree" model="ir.ui.view">
    <field name="name">clinic.customer.tree</field>
    <field name="model">clinic.customer</field>
    <field name="arch" type="xml">
      <tree string="Patients">
        <field name="name"/>
        <field name="dob"/>
      </tree>
    </field>
  </record>

  <record id="view_clinic_patient_form" model="ir.ui.view">
    <field name="name">clinic.customer.form</field>
    <field name="model">clinic.customer</field>
    <field name="arch" type="xml">
      <form string="Patient">
        <sheet>
          <group>
            <field name="name"/>
            <field name="dob"/>
            <field name="note"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>
</odoo>
