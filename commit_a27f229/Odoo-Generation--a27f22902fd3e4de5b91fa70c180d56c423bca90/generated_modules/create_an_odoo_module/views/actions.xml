                <p class="o_view_nocontent_smiling_face">Schedule and manage appointments</p>
            </field>
        </record>
        <record id="consultations_action" model="ir.actions.act_window">
            <field name="name">Consultations</field>
            <field name="res_model">create_an_odoo_module.consultation</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">Record patient consultation details</p>
            </field>
        </record>
    </data>
</odoo>