<odoo>
    <data>
        <!-- Tree View for Medical Department -->
        <record id="create_an_odoo_module.create_an_odoo_module_department_tree_view" model="ir.ui.view">
            <field name="name">create_an_odoo_module.department.tree</field>
            <field name="model">create_an_odoo_module.department</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Medical Department -->
        <record id="create_an_odoo_module.create_an_odoo_module_department_form_view" model="ir.ui.view">
            <field name="name">create_an_odoo_module.department.form</field>
            <field name="model">create_an_odoo_module.department</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>