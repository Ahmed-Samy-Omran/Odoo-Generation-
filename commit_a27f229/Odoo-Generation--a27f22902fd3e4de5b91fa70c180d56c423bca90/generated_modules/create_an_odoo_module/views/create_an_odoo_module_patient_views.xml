<odoo>
    <data>
        <!-- Tree View for Patient -->
        <record id="create_an_odoo_module.create_an_odoo_module_patient_tree_view" model="ir.ui.view">
            <field name="name">create_an_odoo_module.patient.tree</field>
            <field name="model">create_an_odoo_module.patient</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="phone"/>
                    <field name="date_of_birth"/>
                    <field name="gender"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Patient -->
        <record id="create_an_odoo_module.create_an_odoo_module_patient_form_view" model="ir.ui.view">
            <field name="name">create_an_odoo_module.patient.form</field>
            <field name="model">create_an_odoo_module.patient</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="phone"/>
                            <field name="address"/>
                            <field name="date_of_birth"/>
                            <field name="gender"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>