<odoo>
    <data>
        <!-- Tree View for  -->
        <record id="the_user_wants_to.fitzone_membership_tree_view" model="ir.ui.view">
            <field name="name">fitzone.membership.tree</field>
            <field name="model">fitzone.membership</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="member_id"/>
                    <field name="plan_ids"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                </tree>
            </field>
        </record>

        <!-- Form View for  -->
        <record id="the_user_wants_to.fitzone_membership_form_view" model="ir.ui.view">
            <field name="name">fitzone.membership.form</field>
            <field name="model">fitzone.membership</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="member_id"/>
                            <field name="plan_ids"/>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="state"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>