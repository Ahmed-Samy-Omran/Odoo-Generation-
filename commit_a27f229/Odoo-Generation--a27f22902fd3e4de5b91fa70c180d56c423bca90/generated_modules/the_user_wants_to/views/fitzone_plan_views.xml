<odoo>
    <data>
        <!-- Tree View for  -->
        <record id="the_user_wants_to.fitzone_plan_tree_view" model="ir.ui.view">
            <field name="name">fitzone.plan.tree</field>
            <field name="model">fitzone.plan</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="price"/>
                    <field name="duration_days"/>
                </tree>
            </field>
        </record>

        <!-- Form View for  -->
        <record id="the_user_wants_to.fitzone_plan_form_view" model="ir.ui.view">
            <field name="name">fitzone.plan.form</field>
            <field name="model">fitzone.plan</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="price"/>
                            <field name="duration_days"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>