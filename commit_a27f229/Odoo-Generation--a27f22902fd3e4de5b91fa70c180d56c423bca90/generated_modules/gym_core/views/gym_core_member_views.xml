<odoo>
    <data>
        <!-- Tree View for Manages gym members. -->
        <record id="gym_core_member_tree_view" model="ir.ui.view">
            <field name="name">gym_core.member.tree</field>
            <field name="model">gym_core.member</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="membership_type_id"/>
                    <field name="trainer_id"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Manages gym members. -->
        <record id="gym_core_member_form_view" model="ir.ui.view">
            <field name="name">gym_core.member.form</field>
            <field name="model">gym_core.member</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="registration_date"/>
                            <field name="membership_type_id"/>
                            <field name="trainer_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>