<odoo>
    <data>
        <!-- Tree View for Demo Model -->
        <record id="demo_deploy.demo_deploy_model_tree_view" model="ir.ui.view">
            <field name="name">demo_deploy.model.tree</field>
            <field name="model">demo_deploy.model</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Demo Model -->
        <record id="demo_deploy.demo_deploy_model_form_view" model="ir.ui.view">
            <field name="name">demo_deploy.model.form</field>
            <field name="model">demo_deploy.model</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>