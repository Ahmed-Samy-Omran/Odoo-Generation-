<odoo>
    <data>
        <!-- Tree View for Library Book -->
        <record id="create_a_simple.library_book_tree_view" model="ir.ui.view">
            <field name="name">library.book.tree</field>
            <field name="model">library.book</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                    <field name="author"/>
                    <field name="publication_date"/>
                </tree>
            </field>
        </record>

        <!-- Form View for Library Book -->
        <record id="create_a_simple.library_book_form_view" model="ir.ui.view">
            <field name="name">library.book.form</field>
            <field name="model">library.book</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="author"/>
                            <field name="publication_date"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>





    </data>
</odoo>