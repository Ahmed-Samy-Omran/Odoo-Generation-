# ============================================================
# Odoo AI Module Generator - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---- AI Provider Keys (at least ONE is required) -----------

# Gemini (Google) - direct API key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter (aggregates many models, including Gemini)
OPENROUTER_KEY=your_openrouter_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash

# Bynara / NaraRouter (custom gateway)
BYNARA_KEY=your_bynara_key_here
BYNARA_URL=https://router.bynara.id/v1
BYNARA_MODELS=claude-sonnet-4.5,mistral-large,claude-haiku-4.5

# ---- AI Provider Order (optional) -------------------------
# Comma-separated list; first working provider is used
# Choices: nara, gemini, openrouter
AI_PROVIDER_ORDER=nara,gemini,openrouter

# ---- GitHub Deployment (optional) -------------------------
# Only needed if you want git_deploy_target: "github"
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USER=your_github_username

# ---- RAG Service (optional, uses defaults if not set) ------
RAG_PERSIST_DIRECTORY=chroma_db
RAG_COLLECTION_NAME=odoo_reference
RAG_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
RAG_ODDO_ADDONS_PATH=odoo/addons
